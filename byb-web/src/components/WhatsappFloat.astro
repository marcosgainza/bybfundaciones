---
import { site } from '../data/site';
---

<a
  class="wa-float"
  href={`https://wa.me/${site.whatsapp}`}
  target="_blank"
  rel="noopener"
  aria-label="Escribinos por WhatsApp"
>
  <svg width="30" height="30" viewBox="0 0 24 24" fill="#fff">
    <path d="M17.5 14.4c-.3-.2-1.7-.8-2-.9-.3-.1-.5-.2-.7.2-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6l.5-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.2-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.1-.3-.2-.6-.3M12 2a10 10 0 00-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1012 2"></path>
  </svg>
</a>

<style>
  .wa-float {
    position: fixed;
    right: 22px;
    bottom: 22px;
    z-index: 60;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: #25d366;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px -6px rgba(37, 211, 102, 0.6);
    transition: transform 0.25s ease;
  }
  .wa-float:hover {
    transform: scale(1.06);
  }
  @media (max-width: 480px) {
    .wa-float {
      right: 16px;
      bottom: 16px;
      width: 52px;
      height: 52px;
    }
  }
</style>
