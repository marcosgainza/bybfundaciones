---
import { site } from '../data/site';
import { withBase } from '../lib/url';

const nav = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#metodologia', label: 'Metodología' },
  { href: '#casos', label: 'Casos' },
  { href: '#faq', label: 'Preguntas' },
  { href: '#nosotros', label: 'Nosotros' },
];
---

<header class="hdr">
  <div class="hdr-inner container">
    <a href="#inicio" class="brand" aria-label={`${site.name} — inicio`}>
      <img
        src={withBase('/assets/logo/logo-header.png')}
        alt={site.name}
        width="145"
        height="106"
        class="brand-logo"
      />
      <span class="brand-lockup">
        <span class="bl-row">
          <span class="bl-line"></span>
          <span class="bl-title">Ingeniería</span>
          <span class="bl-line"></span>
        </span>
        <span class="bl-row bl-row-mid">
          <span class="bl-line bl-line-thin"></span>
          <span class="bl-dot"></span>
          <span class="bl-line bl-line-thin"></span>
        </span>
        <span class="bl-row">
          <span class="bl-sub-dot"></span>
          <span class="bl-sub">Refuerzo de Fundaciones</span>
          <span class="bl-sub-dot"></span>
        </span>
      </span>
    </a>

    <!-- Botón menú móvil -->
    <button class="hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="site-nav">
      <span></span><span></span><span></span>
    </button>

    <nav id="site-nav" class="nav" aria-label="Navegación principal">
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      <a href="#contacto" class="nav-cta cta-pulse">Evaluación técnica</a>
    </nav>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .hdr-inner {
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .brand-logo {
    height: 100px;
    width: auto;
    flex: 0 0 auto;
  }
  .brand-lockup {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding-left: 2px;
  }
  .bl-row {
    display: flex;
    align-items: center;
    gap: 11px;
  }
  .bl-row-mid {
    gap: 9px;
    width: 100%;
  }
  .bl-line {
    width: 24px;
    height: 1.5px;
    background: var(--navy);
  }
  .bl-line-thin {
    flex: 1;
    background: var(--gray);
  }
  .bl-title {
    font-weight: 700;
    font-size: 21px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--navy);
    padding-left: 0.32em;
  }
  .bl-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--navy);
    flex: 0 0 auto;
  }
  .bl-sub-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gray);
  }
  .bl-sub {
    font-size: 8.5px;
    font-weight: 600;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--gray);
    padding-left: 0.26em;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: clamp(12px, 2vw, 30px);
  }
  .nav > a {
    font-size: 13.5px;
    font-weight: 600;
    color: #3a4150;
    transition: color 0.2s ease;
  }
  .nav > a:hover {
    color: var(--navy);
  }
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: var(--accent-ink) !important;
    font-size: 13px;
    font-weight: 700;
    padding: 11px 18px;
    border-radius: 4px;
  }
  .nav-cta:hover {
    background: var(--accent-hover);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
  }
  .hamburger span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--navy);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.2s ease;
  }
  .hamburger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ---------- Tablet ---------- */
  @media (max-width: 1024px) {
    .brand-logo {
      height: 72px;
    }
    .bl-title {
      font-size: 17px;
    }
  }

  /* ---------- Móvil ---------- */
  @media (max-width: 860px) {
    :root {
      --header-h: 76px;
    }
    .hdr-inner {
      height: 76px;
    }
    .brand {
      gap: 10px;
    }
    .brand-logo {
      height: 56px;
    }
    .brand-lockup {
      gap: 5px;
    }
    .bl-row {
      gap: 7px;
    }
    .bl-line {
      width: 16px;
    }
    .bl-title {
      font-size: 14px;
      letter-spacing: 0.22em;
      padding-left: 0.22em;
    }
    .bl-sub {
      font-size: 6.5px;
      letter-spacing: 0.16em;
      padding-left: 0.16em;
    }
    .hamburger {
      display: flex;
    }
    .nav {
      position: fixed;
      inset: 76px 0 auto 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: #fff;
      border-bottom: 1px solid var(--line);
      box-shadow: 0 16px 30px -18px rgba(13, 43, 91, 0.4);
      padding: 8px 0 16px;
      transform: translateY(-120%);
      transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
      visibility: hidden;
    }
    .nav.open {
      transform: translateY(0);
      visibility: visible;
    }
    .nav > a {
      padding: 15px var(--gutter);
      font-size: 15px;
      border-bottom: 1px solid var(--line);
    }
    .nav-cta {
      margin: 12px var(--gutter) 0;
      justify-content: center;
      padding: 14px 18px;
      font-size: 14px;
      border-bottom: none !important;
    }
  }

  /* ---------- Móvil chico ---------- */
  @media (max-width: 380px) {
    .brand-logo {
      height: 48px;
    }
    .bl-title {
      font-size: 12px;
      letter-spacing: 0.16em;
    }
    .bl-line {
      width: 12px;
    }
    .bl-sub {
      font-size: 5.5px;
    }
  }
</style>

<script>
  const btn = document.querySelector('.hamburger');
  const nav = document.getElementById('site-nav');
  if (btn && nav) {
    const close = () => {
      nav.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Abrir menú');
    };
    btn.addEventListener('click', () => {
      const open = nav.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    });
    // Cerrar al tocar un enlace
    nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
  }
</script>
